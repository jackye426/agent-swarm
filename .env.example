SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection for LangGraph checkpointer (NOT the connection pooler).
# Supabase dashboard → Settings → Database → Connection string (URI / port 5432).
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=TaskGraph OS

# Role-based model routing through OpenRouter.
MODEL_PLANNING_A=anthropic/claude-opus-4.8
MODEL_PLANNING_B=openai/gpt-5.5
MODEL_PLANNING_A_REVIEW=anthropic/claude-opus-4.8
MODEL_PLANNING_B_REVIEW=openai/gpt-5.5
MODEL_PLANNING_CONSENSUS=anthropic/claude-opus-4.8
MODEL_CONTRACT_DRAFT=anthropic/claude-opus-4.8
MODEL_CONTRACT_REVISION=anthropic/claude-opus-4.8
MODEL_ENGINEERING_PLAN=anthropic/claude-opus-4.8
MODEL_VERIFICATION=openai/gpt-5.5

# Scheduler
SCHEDULER_POLL_INTERVAL_MS=5000
SCHEDULER_VISIBILITY_TIMEOUT_S=120

# Engineering Cell execution worker.
# This is separate from model routing: it invokes the actual implementation tool.
TASKGRAPH_WORKTREE_ROOT=C:\tmp\taskgraph-os
CLAUDE_CODE_COMMAND=claude
# JSON array. Defaults to ["--print", implementationPlan].
# CLAUDE_CODE_ARGS=["--print","implement the approved task contract"]
CLAUDE_CODE_TIMEOUT_MS=1800000
TASKGRAPH_DEFAULT_TEST_COMMANDS=npm run typecheck,npm test
TASKGRAPH_TEST_TIMEOUT_MS=600000
TASKGRAPH_EVIDENCE_SOURCE_URL=https://localhost/taskgraph-os

# GitHub PR creation through GitHub CLI.
GITHUB_CREATE_PR=false
