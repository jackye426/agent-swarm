SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Retry transient fetch failures (TypeError: fetch failed) before giving up.
TASKGRAPH_SUPABASE_RETRY_ATTEMPTS=5
TASKGRAPH_SUPABASE_RETRY_BASE_MS=500

# Direct Postgres connection for LangGraph checkpointer (NOT the connection pooler).
# Supabase dashboard → Settings → Database → Connection string (URI / port 5432).
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.okpbevwdqgzmnrowifcn.supabase.co:5432/postgres
# Local smoke escape hatch: set true to use MemorySaver even when DATABASE_URL is set.
TASKGRAPH_DISABLE_POSTGRES_CHECKPOINT=false
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=TaskGraph OS

# Role-based model routing through OpenRouter.
# Default below: cheap test profile (z-ai/glm-5.2 + deepseek/deepseek-v4-pro).
# For production dogfood on hard tasks, switch back to stronger models per role.
MODEL_PLANNING_A=z-ai/glm-5.2
MODEL_PLANNING_B=deepseek/deepseek-v4-pro
MODEL_PLANNING_A_REVIEW=deepseek/deepseek-v4-pro
MODEL_PLANNING_B_REVIEW=z-ai/glm-5.2
MODEL_PLANNING_CONSENSUS=deepseek/deepseek-v4-pro
MODEL_CONTRACT_DRAFT=deepseek/deepseek-v4-pro
MODEL_CONTRACT_REVISION=deepseek/deepseek-v4-pro
MODEL_ENGINEERING_PLAN=z-ai/glm-5.2
MODEL_VERIFICATION=deepseek/deepseek-v4-pro
MODEL_VERIFICATION_MAX_TOKENS=8192
# Conversational Telegram intake (plain-language requirements → task chain).
# Use a strong model here — it decomposes vague asks into scoped tasks.
MODEL_INTAKE_CONVERSATION=anthropic/claude-opus-4.8

# Scheduler
SCHEDULER_POLL_INTERVAL_MS=5000
SCHEDULER_VISIBILITY_TIMEOUT_S=120
SCHEDULER_WORKERS=1
TASKGRAPH_MAX_REWORK_ATTEMPTS=3

# Engineering Cell execution worker.
# This is separate from model routing: it invokes the actual implementation tool.
TASKGRAPH_WORKTREE_ROOT=C:\tmp\taskgraph-os
CLAUDE_CODE_COMMAND=claude
# JSON array. Defaults to ["--print", implementationPlan].
# CLAUDE_CODE_ARGS=["--print","implement the approved task contract"]
CLAUDE_CODE_TIMEOUT_MS=1800000
TASKGRAPH_DEFAULT_TEST_COMMANDS=npm run typecheck,npm test
TASKGRAPH_TEST_TIMEOUT_MS=600000
TASKGRAPH_EVIDENCE_SOURCE_URL=https://localhost/taskgraph-os

# GitHub PR creation through GitHub CLI (verification prefers gh pr diff when set).
GITHUB_CREATE_PR=false

# Intake auto-dispatch (requires always-on npm run scheduler).
TASKGRAPH_AUTO_ENQUEUE_EXECUTION=false
TASKGRAPH_AUTO_ENQUEUE_VERIFICATION=false
# Token for cloning private repos during seed scan (optional for public repos).
GITHUB_TOKEN=

# Default target repo when intake cannot resolve one (dev/fallback — not primary production path).
TASKGRAPH_DEFAULT_REPO=owner/repo

# Reuse seed repo scan cache if younger than this many milliseconds (default 10 minutes).
REPO_CACHE_MAX_AGE_MS=600000

# Telegram bot (intake server).
# Get token from @BotFather on Telegram. Get chat ID from @userinfobot.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# GitHub webhook secret — set the same string in GitHub repo → Settings → Webhooks.
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Port for the intake HTTP server (GitHub webhook receiver).
INTAKE_PORT=3000

# Notification watcher polling fallback (backs up Supabase Realtime; see
# migration 005). Poll cadence and how far back the first poll looks.
NOTIFY_POLL_INTERVAL_MS=60000
NOTIFY_POLL_LOOKBACK_MS=600000

# --- Startup gate (scripts/start-gated.ts, used by pm2) ---
# In-process healthcheck retries before exiting 1. Rides out cold-boot network
# warmup (10 × 15 s ≈ 2.5 min) without inflating pm2's exponential backoff.
STARTGATE_HEALTHCHECK_ATTEMPTS=10
STARTGATE_RETRY_DELAY_MS=15000

# --- Watchdog (npm run watchdog; third pm2 app) ---
# How often to run checks (default 5 min) and how long before a persistent
# condition re-alerts (default 1 h).
WATCHDOG_INTERVAL_MS=300000
WATCHDOG_REALERT_MS=3600000
# Task stuck threshold. Must exceed the longest legitimate run
# (CLAUDE_CODE_TIMEOUT_MS, default 30 min). Default 45 min.
WATCHDOG_STUCK_TASK_MS=2700000
WATCHDOG_QUEUE_DEPTH_THRESHOLD=10
WATCHDOG_MIN_FREE_DISK_GB=5
# Off-host dead-man's switch: watchdog pings this healthchecks.io URL each
# cycle; a missed ping alerts from OUTSIDE the host (host death is otherwise
# silent — Telegram alerts die with the machine). Leave empty to disable.
HEALTHCHECKS_PING_URL=

# --- Healthcheck (npm run healthcheck) ---
# Always required: SUPABASE_*, OPENROUTER_API_KEY, CLAUDE_CODE_COMMAND, TASKGRAPH_WORKTREE_ROOT, git.
# Also probed when set: GITHUB_TOKEN or GITHUB_CREATE_PR=true (gh auth / token),
# DATABASE_URL (unless TASKGRAPH_DISABLE_POSTGRES_CHECKPOINT=true), TELEGRAM_BOT_TOKEN (getMe).
# Optional warnings (fail with --strict): TELEGRAM_CHAT_ID, GITHUB_WEBHOOK_SECRET when intake is configured.
# Flags: --json (machine output), --strict (treat optional intake warnings as failures).
